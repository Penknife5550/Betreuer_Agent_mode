# =====================================================================
# Betreuer-App  .env
# =====================================================================
# Eine einzige Beispiel-Datei fuer Dev UND Prod.
# Auf dem Server bzw. lokal kopieren:   cp .env.example .env
# NIEMALS committen (steht in .gitignore).
#
# Annotations:
#   # DEV:  gilt nur fuer lokale Entwicklung
#   # PROD: gilt nur fuer Produktivbetrieb
#   # !    Pflicht -- sonst startet die Anwendung nicht
#   # GEN: Vorgeschlagener Generator-Command fuer Secrets
# =====================================================================


# --- 0. Multi-Mandant -------------------------------------------------

# ! MANDANT: Kurzname fuer die Installation. Wird in Container-,
# Volume- und Netzwerk-Namen eingesetzt, damit mehrere Mandanten
# parallel auf demselben Docker-Host laufen koennen.
# Erlaubt: kleinbuchstaben, ziffern, bindestrich. Keine Sonderzeichen.
# Beispiele: fes, csfv-minden, schule-xy.
MANDANT=fes


# --- 1. Django Core ---------------------------------------------------

# ! SECRET_KEY: mindestens 50 Zeichen, urlsafe.
# GEN: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ODER: openssl rand -base64 60 | tr -d '\n'
# DEV: Default unten ist OK, PROD: unbedingt ersetzen (Hard-Fail beim Start).
SECRET_KEY=django-insecure-change-me-in-production

# DEV: True   | PROD: False
DEBUG=True

# DEV: betreuer_project.settings.development
# PROD: betreuer_project.settings.production
DJANGO_SETTINGS_MODULE=betreuer_project.settings.development

# DEV: localhost,127.0.0.1
# PROD: betreuer.fes-credo.de   (komma-getrennt, kein Schema/Port)
ALLOWED_HOSTS=localhost,127.0.0.1

# HTTP->HTTPS-Redirect in Django.
# PROD: leer lassen -- Caddy erledigt den Redirect automatisch.
# Nur auf True setzen, wenn Django OHNE Caddy direkt aus dem Internet
# erreichbar ist. Achtung: dann muss "X-Forwarded-Proto: https" vom
# Proxy verlaesslich gesetzt sein, sonst entsteht ein Redirect-Loop.
SECURE_SSL_REDIRECT=False


# --- 2. Datenbank -----------------------------------------------------

# Postgres-Container-Variablen (werden von docker-compose.yml genutzt).
POSTGRES_DB=betreuer_db
POSTGRES_USER=betreuer_user
# ! POSTGRES_PASSWORD: min. 24 Zeichen, nur alphanumerisch empfohlen.
# GEN: openssl rand -base64 24 | tr -d '+/=' | cut -c1-24
# DEV: einfaches Passwort unten ist OK, PROD: zwingend neu generieren.
POSTGRES_PASSWORD=betreuer_pass_dev

# Django liest die gleichen Werte mit anderen Namen; behalten wir
# synchron per Variable-Expansion.
DB_NAME=${POSTGRES_DB}
DB_USER=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}
# Innerhalb Docker: Service-Name "postgres"
# Auf Host-Python (ohne Docker): "localhost"
DB_HOST=postgres
DB_PORT=5432

# Connection-Pool-Zeit in Sekunden (0 = keine Persistenz).
DB_CONN_MAX_AGE=60


# --- 3. Verschluesselung (IBAN-Migration) ----------------------------

# ! FERNET_KEY: exakt 44 Zeichen, urlsafe-base64.
# GEN: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Hinweis: Im aktuellen Code-Stand ist die IBAN ein Klartext-CharField
# (V2-Migration). FERNET_KEY wird nur noch von der einmaligen
# Datenmigration 0006_decrypt_iban_data benoetigt, falls historische
# V1-Daten (Fernet-verschluesselte IBANs) entschluesselt werden muessen.
# Auf einer frischen DB ist die Migration ein No-Op; production.py
# erzwingt den Key trotzdem als Vorsichtsmassnahme -- einfach einen
# generieren und eintragen.
FERNET_KEY=


# --- 4. E-Mail (SMTP) -------------------------------------------------

# Alle App-Mails (Einladung, Passwort-Setzen, Benachrichtigungen) gehen
# DIREKT per SMTP (nicht mehr ueber n8n).
#
# Bevorzugt werden die SMTP-Zugangsdaten + Rollen-Adressen (Admin,
# Buchhaltung) im Django-Admin unter "SMTP-Konfiguration" gepflegt
# (aenderbar ohne Re-Deploy). Ist dort KEINE aktive Config hinterlegt,
# greifen die folgenden .env-Werte als Fallback.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
# ! EMAIL_HOST_PASSWORD: SMTP-Zugangsdaten vom Provider.
# GEN: vom Mail-Anbieter kopieren, kein Generator.
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@fes-credo.de
SERVER_EMAIL=noreply@fes-credo.de

# Basis-URL fuer Links in E-Mails (Einladung, Passwort-Setzen).
# Optional: leer lassen -> in Produktion automatisch https://<erste ALLOWED_HOSTS-Domain>.
SITE_BASE_URL=

# Komma-separierte Liste "Name:email,Name:email".
# Erhalten automatische 500er-Error-Mails.
# Beispiel: "Dimitri Riesen:dimitri.riesen@fes-minden.de"
DJANGO_ADMINS=


# --- 5. n8n-Integration ----------------------------------------------
#
# Webhook-URL UND Bearer-Token werden hier NICHT mehr konfiguriert.
# Sie liegen in der DB und werden im Django-Admin gepflegt:
#
#   /django-admin/notifications/webhookendpoint/   (ausgehend)
#   /django-admin/notifications/inboundtoken/      (eingehend)
#
# Nach erstem Boot: Superuser anlegen
#   docker compose exec django python manage.py createsuperuser
# und die Webhook-Endpoints + Inbound-Token eintragen.
#
# Empfohlener Generator fuer den Inbound-Token:
#   openssl rand -hex 32
# (64 Zeichen hex, sicher fuer Bearer-Header).


# --- 6. Cron / Django-Q -----------------------------------------------

# Optional: Shared-Secret fuer /cron/-Endpoints falls spaeter eingebaut.
# GEN: openssl rand -hex 24
CRON_SECRET=
