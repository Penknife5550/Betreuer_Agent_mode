# =============================================================================
# Caddy-Konfiguration fuer Betreuer-App
# =============================================================================
# Diesen Block in die bestehende Caddyfile einfuegen (z.B. neben
# finance.fes-credo.de). SSL/TLS wird automatisch von Caddy verwaltet.
# Caddy muss im selben Docker-Netzwerk "reverse_proxy" sein.
#
# WICHTIG: Der Container-Name enthaelt den MANDANT aus der .env.
# Beispiel MANDANT=fes -> Container heisst "betreuer-fes-django".
# Statische Dateien werden von WhiteNoise IM Django-Container ausgeliefert
# -- Caddy braucht keinen file_server-Block.
# =============================================================================

betreuer.fes-credo.de {
	reverse_proxy betreuer-fes-django:8000

	# Security Headers (Django setzt zusaetzlich CSP / Permissions-Policy
	# via apps.core.security_headers.SecurityHeadersMiddleware)
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy same-origin
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}

	encode zstd gzip

	log {
		output file /var/log/caddy/betreuer.log
		format json
	}
}
