# ============================================================
# PRODUKTION - Umgebungsvariablen für betreuer.fes-minden.de
# ============================================================
# Diese Datei auf dem Server als ".env" speichern (NICHT ".env.prod.example")
# NIEMALS in Git committen!
#
# Auf dem Server: cp .env.prod.example .env  →  dann Werte eintragen

# --- Django Core ---
SECRET_KEY=HIER_NEUEN_KEY_EINTRAGEN
DEBUG=False
DJANGO_SETTINGS_MODULE=betreuer_project.settings.production

# --- Erlaubte Hosts (Domain ohne https://) ---
ALLOWED_HOSTS=betreuer.fes-minden.de

# --- Datenbank ---
DB_NAME=betreuer_db
DB_USER=betreuer_user
DB_PASSWORD=HIER_SICHERES_PASSWORT_EINTRAGEN
DB_HOST=postgres
DB_PORT=5432

# Für den PostgreSQL-Container (gleiche Werte wie oben)
POSTGRES_DB=betreuer_db
POSTGRES_USER=betreuer_user
POSTGRES_PASSWORD=HIER_SICHERES_PASSWORT_EINTRAGEN

# --- Verschlüsselung (IBAN) ---
# WICHTIG: Einmal gesetzt, NIEMALS mehr ändern – sonst sind alle IBANs unlesbar!
FERNET_KEY=HIER_FERNET_KEY_EINTRAGEN

# --- N8N Integration ---
N8N_WEBHOOK_BASE_URL=https://n8n.fes-minden.de
# Token fuer eingehende N8N-Callbacks (muss in N8N ebenfalls konfiguriert werden)
N8N_API_TOKEN=HIER_N8N_TOKEN_EINTRAGEN

# --- E-Mail (SMTP) ---
# Pflicht fuer Password-Reset-Mails und Fehler-Benachrichtigungen an Admins.
# Wenn leer bleibt, nutzt Django das Dummy-Backend und verschickt NICHTS.
EMAIL_HOST=smtp.example.de
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@fes-minden.de
EMAIL_HOST_PASSWORD=HIER_SMTP_PASSWORT_EINTRAGEN
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@fes-minden.de
SERVER_EMAIL=noreply@fes-minden.de
# Komma-separierte Liste Name:Email fuer 500er-Error-Mails
DJANGO_ADMINS=Dimitri Riesen:dimitri.riesen@fes-minden.de

# --- Datenbank-Connection-Pool ---
DB_CONN_MAX_AGE=60
